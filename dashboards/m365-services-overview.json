      "description": "user_key is the opaque classic UserKey; user_id is usually the UPN but carries sentinels too. Correlate the two M365 audit transports on user_id.\n\nNeeds a **Loki** datasource (selected above). Log attributes are Loki *structured metadata*, not stream labels: filter with `| event_name=\u2026` after `{service_name=\"graph2otel\"}`. A stream selector on an attribute matches zero rows silently (#90).",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 138
      },
      "datasource": {
        "type": "loki",
        "uid": "${loki_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "No rows. Either no Loki datasource is selected above, or nothing matched. Log attributes are structured metadata: filter with | attr=\u2026 after {service_name=\"graph2otel\"}, never {attr=\"\u2026\"}."
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"graph2otel\"} | event_name=`m365.audit` | tenant_id=~\"$tenant\"",
          "datasource": {
            "type": "loki",
            "uid": "${loki_datasource}"
