{
  "Metrics": [
    {
      "Name": "entra.graph_activity.endpoint_requests",
      "Unit": "{request}",
      "Kind": "sum",
      "AttrKeys": [
        "normalized_path",
        "request_method",
        "response_status_class"
      ]
    },
    {
      "Name": "entra.graph_activity.request.duration",
      "Unit": "ms",
      "Kind": "histogram",
      "AttrKeys": [
        "request_method"
      ]
    },
    {
      "Name": "entra.graph_activity.requests",
      "Unit": "{request}",
      "Kind": "sum",
      "AttrKeys": [
        "identity_type",
        "is_replay",
        "request_method",
        "response_status_code"
      ]
    },
    {
      "Name": "entra.graph_activity.response.size",
      "Unit": "By",
      "Kind": "histogram",
      "AttrKeys": [
        "request_method"
      ]
    },
    {
      "Name": "graph2otel.blob.endpoint_paths",
      "Unit": "{path}",
      "Kind": "gauge",
      "AttrKeys": [
        "collector"
      ]
    },
    {
      "Name": "graph2otel.blob.event_age",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "collector"
      ]
    },
    {
      "Name": "graph2otel.blob.metric_emitted",
      "Unit": "{record}",
      "Kind": "sum",
      "AttrKeys": [
        "collector"
      ]
    },
    {
      "Name": "graph2otel.blob.metric_gated",
      "Unit": "{record}",
      "Kind": "sum",
      "AttrKeys": [
        "collector"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "entra.graph_activity",
      "AttrKeys": [
        "api_version",
        "app_id",
        "caller_ip_address",
        "client_request_id",
        "correlation_id",
        "duration_ms",
        "identity_provider",
        "identity_type",
        "ingest_transport",
        "is_replay",
        "location",
        "operation_id",
        "request_id",
        "request_method",
        "request_uri",
        "response_size_bytes",
        "response_status_code",
        "roles",
        "service_principal_id",
        "sign_in_activity_id",
        "token_issued_at",
        "user_agent",
        "user_principal_object_id",
        "wids"
      ]
    }
  ]
}
