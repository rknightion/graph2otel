{
  "Metrics": [
    {
      "Name": "purview.dlp.policies",
      "Unit": "{policy}",
      "Kind": "gauge",
      "AttrKeys": [
        "enforcement_mode"
      ]
    },
    {
      "Name": "purview.dlp.policy.last_changed_age",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": []
    },
    {
      "Name": "purview.dlp.policy_bindings",
      "Unit": "{binding}",
      "Kind": "gauge",
      "AttrKeys": [
        "binding_type",
        "workload"
      ]
    },
    {
      "Name": "purview.dlp.rules",
      "Unit": "{rule}",
      "Kind": "gauge",
      "AttrKeys": [
        "action",
        "workload"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "purview.dlp_policy",
      "AttrKeys": [
        "bound_workloads",
        "enforcement_mode",
        "policy_id",
        "policy_name",
        "when_changed_utc",
        "when_rules_changed_utc"
      ]
    },
    {
      "EventName": "purview.dlp_rule",
      "AttrKeys": [
        "actions",
        "enabled",
        "enforcement_mode",
        "last_modified_utc",
        "management_rule_id",
        "max_confidence",
        "max_count",
        "min_confidence",
        "min_count",
        "policy_id",
        "rule_id",
        "rule_name",
        "sensitive_info_type_ids",
        "severity",
        "workload"
      ]
    }
  ]
}
