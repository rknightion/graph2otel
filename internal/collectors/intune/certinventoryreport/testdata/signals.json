{
  "Metrics": [
    {
      "Name": "graph2otel.api.unexpected",
      "Unit": "1",
      "Kind": "sum",
      "AttrKeys": [
        "collector",
        "field",
        "kind"
      ]
    },
    {
      "Name": "intune.cert_inventory.days_until_expiry",
      "Unit": "{certificate}",
      "Kind": "gauge",
      "AttrKeys": [
        "bucket",
        "issuer"
      ]
    },
    {
      "Name": "intune.cert_inventory.state",
      "Unit": "{certificate}",
      "Kind": "gauge",
      "AttrKeys": [
        "state"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "intune.device_certificate",
      "AttrKeys": [
        "certificate_status",
        "device_id",
        "device_name",
        "enhanced_key_usage",
        "ingest_transport",
        "issuer_name",
        "key_usage",
        "policy_id",
        "serial_number",
        "state_bucket",
        "subject_name",
        "thumbprint",
        "upn",
        "user_id",
        "valid_from",
        "valid_to"
      ]
    }
