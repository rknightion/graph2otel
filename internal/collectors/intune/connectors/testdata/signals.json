{
  "Metrics": [
    {
      "Name": "intune.connector.heartbeat_age_seconds",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "connector_type"
      ]
    },
    {
      "Name": "intune.connector.mtd_platform.total",
      "Unit": "{connector}",
      "Kind": "gauge",
      "AttrKeys": [
        "enabled",
        "platform"
      ]
    },
    {
      "Name": "intune.connector.state",
      "Unit": "{connector}",
      "Kind": "gauge",
      "AttrKeys": [
        "connector_type",
        "state"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "intune.connector",
      "AttrKeys": [
        "bind_status",
        "connector_type",
        "enrollment_target",
        "last_app_sync_status",
        "owner_principal_name"
      ]
    }
  ]
}
