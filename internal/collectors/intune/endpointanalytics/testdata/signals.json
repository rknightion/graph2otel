{
  "Metrics": [
    {
      "Name": "intune.uxa.anomaly_count",
      "Unit": "{anomaly}",
      "Kind": "gauge",
      "AttrKeys": [
        "anomaly_severity"
      ]
    },
    {
      "Name": "intune.uxa.app_crash_count",
      "Unit": "{crash}",
      "Kind": "gauge",
      "AttrKeys": [
        "app_name"
      ]
    },
    {
      "Name": "intune.uxa.app_health.active_device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "os_version"
      ]
    },
    {
      "Name": "intune.uxa.app_health.device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.app_health.mean_time_to_failure_minutes",
      "Unit": "min",
      "Kind": "gauge",
      "AttrKeys": [
        "os_version"
      ]
    },
    {
      "Name": "intune.uxa.app_health.os_version_score",
      "Unit": "{score}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state",
        "os_version"
      ]
    },
    {
      "Name": "intune.uxa.baseline_score",
      "Unit": "{score}",
      "Kind": "gauge",
      "AttrKeys": [
        "baseline_name",
        "is_built_in"
      ]
    },
    {
      "Name": "intune.uxa.battery_health.device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.battery_health_score",
      "Unit": "{score}",
      "Kind": "histogram",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.boot_time_ms",
      "Unit": "ms",
      "Kind": "histogram",
      "AttrKeys": [
        "restart_category"
      ]
    },
    {
      "Name": "intune.uxa.device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.device_score",
      "Unit": "{score}",
      "Kind": "histogram",
      "AttrKeys": [
        "category"
      ]
    },
    {
      "Name": "intune.uxa.login_time_ms",
      "Unit": "ms",
      "Kind": "histogram",
      "AttrKeys": [
        "restart_category"
      ]
    },
    {
      "Name": "intune.uxa.resource_performance.device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.resource_performance_score",
      "Unit": "{score}",
      "Kind": "histogram",
      "AttrKeys": [
        "health_state"
      ]
    },
    {
      "Name": "intune.uxa.work_from_anywhere.device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "health_state",
        "upgrade_eligibility"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "intune.app_health",
      "AttrKeys": [
        "active_device_count",
        "app_crash_count",
        "app_display_name",
        "app_hang_count",
        "app_health_score",
        "app_name",
        "app_usage_duration",
        "health_state",
        "mean_time_to_failure_minutes",
        "publisher"
      ]
    },
    {
      "EventName": "intune.device_app_health",
      "AttrKeys": [
        "app_crash_count",
        "app_hang_count",
        "crashed_app_count",
        "device_app_health_score",
        "device_id",
        "device_name",
        "health_state",
        "manufacturer",
        "mean_time_to_failure_minutes",
        "model"
      ]
    },
    {
      "EventName": "intune.device_battery_health",
      "AttrKeys": [
        "battery_age_days",
        "battery_count",
        "battery_health_score",
        "battery_ids",
        "device_id",
        "device_name",
        "estimated_runtime_minutes",
        "full_battery_drain_count",
        "health_state",
        "manufacturer",
        "max_capacity_percentage",
        "model"
      ]
    },
    {
      "EventName": "intune.device_endpoint_analytics",
      "AttrKeys": [
        "app_reliability_score",
        "battery_health_score",
        "device_name",
        "endpoint_analytics_score",
        "health_state",
        "id",
        "manufacturer",
        "model",
        "startup_performance_score",
        "work_from_anywhere_score"
      ]
    },
    {
      "EventName": "intune.device_resource_performance",
      "AttrKeys": [
        "cpu_spike_time_percentage",
        "health_state",
        "ram_spike_time_percentage",
        "resource_performance_score",
        "total_ram_mb"
      ]
    },
    {
      "EventName": "intune.device_startup",
      "AttrKeys": [
        "core_boot_time_ms",
        "core_login_time_ms",
        "device_id",
        "feature_update_boot_time_ms",
        "group_policy_boot_time_ms",
        "group_policy_login_time_ms",
        "is_feature_update",
        "is_first_login",
        "os_version",
        "responsive_desktop_time_ms",
        "restart_category",
        "restart_fault_bucket",
        "restart_stop_code",
        "total_boot_time_ms",
        "total_login_time_ms"
      ]
    },
    {
      "EventName": "intune.device_startup_process",
      "AttrKeys": [
        "device_id",
        "process_name",
        "product_name",
        "publisher",
        "startup_impact_ms"
      ]
    },
    {
      "EventName": "intune.device_work_from_anywhere",
      "AttrKeys": [
        "device_name",
        "health_state",
        "id",
        "manufacturer",
        "model",
        "os",
        "os_version",
        "ownership",
        "processor_family_check_failed",
        "secure_boot_check_failed",
        "serial_number",
        "tpm_check_failed",
        "upgrade_eligibility",
        "windows_score",
        "work_from_anywhere_score"
      ]
    }
  ]
}
