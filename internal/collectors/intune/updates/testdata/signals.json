{
  "Metrics": [
    {
      "Name": "intune.driver_update.pending_approval",
      "Unit": "{update}",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.driver_update.sync_staleness_seconds",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.feature_update_profile.eol_target",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "feature_update_version",
        "profile_name"
      ]
    },
    {
      "Name": "intune.quality_update_config.count",
      "Unit": "{resource}",
      "Kind": "gauge",
      "AttrKeys": [
        "resource_type"
      ]
    },
    {
      "Name": "intune.update_ring.pause_expiry_seconds",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "ring_name",
        "update_type"
      ]
    },
    {
      "Name": "intune.update_ring.pause_state",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "ring_name",
        "update_type"
      ]
    },
    {
      "Name": "intune.update_ring.rollback_active",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "ring_name",
        "update_type"
      ]
    },
    {
      "Name": "intune.update_ring.status",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "ring_name",
        "state"
      ]
    }
  ],
  "Logs": null
}
