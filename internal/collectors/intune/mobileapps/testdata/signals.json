{
  "Metrics": [
    {
      "Name": "intune.mobile_app_config.status",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "policy_name",
        "status"
      ]
    },
    {
      "Name": "intune.mobile_apps.count",
      "Unit": "{app}",
      "Kind": "gauge",
      "AttrKeys": [
        "app_type",
        "publishing_state"
      ]
    }
  ],
  "Logs": null
}
