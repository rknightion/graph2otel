{
  "Metrics": [
    {
      "Name": "intune.app_protection.flagged_registrations",
      "Unit": "{registration}",
      "Kind": "gauge",
      "AttrKeys": [
        "flagged_reason",
        "platform"
      ]
    },
    {
      "Name": "intune.app_protection.policy.count",
      "Unit": "{policy}",
      "Kind": "gauge",
      "AttrKeys": [
        "assigned",
        "platform"
      ]
    },
    {
      "Name": "intune.wip.policy.count",
      "Unit": "{policy}",
      "Kind": "gauge",
      "AttrKeys": [
        "assigned"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "intune.app_registration",
      "AttrKeys": [
        "app_identifier",
        "device_tag",
        "flagged_reasons",
        "platform",
        "user_id"
      ]
    }
  ]
}
