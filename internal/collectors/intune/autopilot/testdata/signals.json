{
  "Metrics": [
    {
      "Name": "graph2otel.api.unexpected",
      "Unit": "1",
      "Kind": "sum",
      "AttrKeys": [
        "collector",
        "field",
        "kind"
      ]
    },
    {
      "Name": "intune.autopilot.devices",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "enrollment_state",
        "group_tag"
      ]
    },
    {
      "Name": "intune.autopilot.profile.assignments",
      "Unit": "{assignment}",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.autopilot.profile.count",
      "Unit": "{profile}",
      "Kind": "gauge",
      "AttrKeys": [
        "device_type",
        "preprovisioning_allowed"
      ]
    },
    {
      "Name": "intune.autopilot.profile.esp_timeout_minutes",
      "Unit": "min",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.autopilot.profile.setting",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name",
        "setting"
      ]
    },
    {
      "Name": "intune.autopilot.stale_contact.count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "group_tag"
      ]
    },
    {
      "Name": "intune.autopilot.sync_age_seconds",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": []
    },
    {
      "Name": "intune.autopilot.sync_status",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "sync_status"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "intune.autopilot.sync",
      "AttrKeys": [
        "id",
        "last_manual_sync_trigger_date_time",
        "last_sync_date_time",
        "sync_status"
      ]
    }
  ]
}
