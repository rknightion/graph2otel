{
  "Metrics": [
    {
      "Name": "intune.autopilot.devices",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "enrollment_state",
        "group_tag"
      ]
    },
    {
      "Name": "intune.autopilot.profile.assignments",
      "Unit": "{assignment}",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.autopilot.profile.count",
      "Unit": "{profile}",
      "Kind": "gauge",
      "AttrKeys": [
        "device_type",
        "preprovisioning_allowed"
      ]
    },
    {
      "Name": "intune.autopilot.profile.esp_timeout_minutes",
      "Unit": "min",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name"
      ]
    },
    {
      "Name": "intune.autopilot.profile.setting",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "profile_name",
        "setting"
      ]
    },
    {
      "Name": "intune.autopilot.stale_contact.count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": [
        "group_tag"
      ]
    }
  ],
  "Logs": null
}
