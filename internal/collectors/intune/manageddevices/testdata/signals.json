        "os_version"
      ]
    },
    {
      "Name": "intune.devices.overview.dual_enrolled_device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": []
    },
    {
      "Name": "intune.devices.overview.enrolled_device_count",
      "Unit": "{device}",
      "Kind": "gauge",
      "AttrKeys": []
