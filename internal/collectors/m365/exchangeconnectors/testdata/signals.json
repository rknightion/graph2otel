        "id",
        "identity",
        "ingest_transport",
        "is_transport_rule_scoped",
        "is_valid",
        "is_validated",
        "last_validation_timestamp",
        "mta_sts_mode",
        "name",
        "require_tls",
        "restrict_domains_to_certificate",
        "restrict_domains_to_ip_addresses",
        "route_all_messages_via_on_premises",
        "sender_domains",
        "sender_ip_addresses",
        "sender_rewriting_enabled",
        "smart_hosts",
        "smtp_dane_mode",
        "test_mode",
        "tls_sender_certificate_name",
