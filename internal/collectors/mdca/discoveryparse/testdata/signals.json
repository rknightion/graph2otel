{
  "Metrics": [
    {
      "Name": "mdca.discovery.parse.cloud_services",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "input_stream_id"
      ]
    },
    {
      "Name": "mdca.discovery.parse.last_success.age",
      "Unit": "s",
      "Kind": "gauge",
      "AttrKeys": [
        "input_stream_id"
      ]
    },
    {
      "Name": "mdca.discovery.parse.tasks",
      "Unit": "1",
      "Kind": "sum",
      "AttrKeys": [
        "input_stream_id",
        "is_success",
        "template"
      ]
    },
    {
      "Name": "mdca.discovery.parse.transactions",
      "Unit": "1",
      "Kind": "gauge",
      "AttrKeys": [
        "input_stream_id"
      ]
    }
  ],
  "Logs": [
    {
      "EventName": "mdca.discovery_parse",
      "AttrKeys": [
        "cloud_services_count",
        "id",
        "ingest_transport",
        "input_stream_id",
        "is_success",
        "state",
        "template",
        "transactions_count"
      ]
    }
  ]
}
