<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>graph2otel admin</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='6' fill='%234493f8'/%3E%3C/svg%3E">
<style>
  :root{
    --bg:#0f1419; --panel:#171c24; --panel2:#1d242e; --line:#2a323d;
    --fg:#e6edf3; --muted:#8b98a5; --accent:#4493f8;
    --ok:#3fb950; --warn:#d29922; --err:#f85149; --info:#a371f7;
    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--fg);
    font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
  code{font-family:var(--mono);font-size:12px;background:var(--panel2);
    padding:1px 5px;border-radius:4px;color:#c9d1d9}
  header{padding:18px 24px;border-bottom:1px solid var(--line);
    display:flex;align-items:baseline;gap:14px;flex-wrap:wrap}
  header h1{margin:0;font-size:19px;font-weight:600}
  header .ver{color:var(--muted);font-family:var(--mono);font-size:13px}
  header .spacer{flex:1}
  main{max-width:1180px;margin:0 auto;padding:18px 24px 60px}
  section{margin:26px 0}
  section>h2{font-size:14px;margin:0 0 4px;font-weight:600}
  section>h2 .tsum{color:var(--muted);font-size:12px;font-weight:400;margin-left:8px}
  .badge{display:inline-block;padding:2px 9px;border-radius:999px;font-size:12px;
    font-weight:600;line-height:1.6}
  .badge.ok{background:rgba(63,185,80,.16);color:var(--ok)}
  .badge.err{background:rgba(248,81,73,.16);color:var(--err)}
  .badge.warn{background:rgba(210,153,34,.16);color:var(--warn)}
  .badge.info{background:rgba(163,113,247,.16);color:var(--info)}
  .badge.pending{background:rgba(110,118,129,.18);color:var(--muted)}
  .badge.muted{background:rgba(110,118,129,.18);color:var(--muted)}
  .reasons{margin:6px 0 0;padding:8px 12px;background:rgba(248,81,73,.08);
    border:1px solid var(--line);border-radius:8px;color:var(--muted);font-size:12px}
  .reasons ul{margin:4px 0 0;padding-left:18px}
  table{width:100%;border-collapse:collapse;background:var(--panel);
    border:1px solid var(--line);border-radius:10px;overflow:hidden;margin-top:8px}
  th,td{text-align:left;padding:8px 12px;border-bottom:1px solid var(--line);
    font-variant-numeric:tabular-nums;vertical-align:middle}
  th{color:var(--muted);font-size:12px;font-weight:600;background:var(--panel2)}
  tr:last-child td{border-bottom:0}
  td.num{text-align:right;font-family:var(--mono)}
  tr.bad>td{background:rgba(248,81,73,.07)}
  tr.skip>td{color:var(--muted)}
  .mono{font-family:var(--mono);font-size:12px;overflow-wrap:anywhere}
  .muted{color:var(--muted)}
  svg.spark{width:84px;height:22px;vertical-align:middle;display:inline-block;
    fill:none;stroke:var(--accent);stroke-width:1.5;stroke-linejoin:round;stroke-linecap:round}
  .outcome{display:inline-flex;gap:2px;align-items:center}
  .outcome i{width:4px;height:13px;border-radius:1px;background:var(--ok);display:inline-block}
  .outcome i.f{background:var(--err)}
  footer{max-width:1180px;margin:0 auto;padding:0 24px 40px;color:var(--muted);font-size:12px}
</style>
</head>
<body>
<header>
  <h1>graph2otel</h1>
  <span class="ver">{{.Service.Version}} &middot; {{.Service.GoVersion}}</span>
  <span class="ver">up {{.Service.Uptime}} &middot; started {{.Service.StartedAt}}</span>
  <span class="spacer"></span>
  <span class="badge {{healthClass .Health}}" title="{{range .HealthReasons}}{{.}}&#10;{{end}}">{{.Health}}</span>
</header>
<main>
  {{if .HealthReasons}}
  <div class="reasons">
    <strong>Why not healthy:</strong>
    <ul>{{range .HealthReasons}}<li>{{.}}</li>{{end}}</ul>
  </div>
  {{end}}

  {{range .Tenants}}
  <section>
    <h2>Tenant <code>{{.TenantID}}</code>
      <span class="tsum">{{.EnabledCount}} active{{if .FailingCount}} &middot; {{.FailingCount}} failing{{end}}{{if .PendingCount}} &middot; {{.PendingCount}} starting{{end}}{{if .CoveredCount}} &middot; {{.CoveredCount}} covered{{end}}{{if .SkippedCount}} &middot; {{.SkippedCount}} skipped{{end}}</span>
    </h2>
    <table>
      <thead><tr>
        <th>Collector</th><th>State</th><th class="num">Interval</th>
        <th class="num">Success</th><th class="num">Runs</th><th class="num">Failures</th>
        <th class="num">Next run</th><th class="num">Duration</th><th>Recent</th>
        <th>Staleness</th><th>Last error</th>
      </tr></thead>
      <tbody>
      {{range .Collectors}}
        {{if .Enabled}}
        <tr{{if and .HasRun (not .LastSuccess)}} class="bad"{{end}}>
          <td><code>{{.Name}}</code></td>
          <td>{{if not .HasRun}}<span class="badge pending">starting</span>{{else if .LastSuccess}}<span class="badge ok">ok</span>{{else}}<span class="badge err">failing</span>{{end}}{{if .Transport}} <span class="muted mono" title="ingest transport">via {{.Transport}}</span>{{end}}</td>
          <td class="num">{{.IntervalSec}}s</td>
          <td class="num">{{if .HasRun}}{{printf "%.0f" .SuccessRatePct}}%{{else}}<span class="muted">&mdash;</span>{{end}}</td>
          <td class="num">{{.Runs}}</td>
          <td class="num">{{.Failures}}{{if gt .ConsecutiveFailures 0}} <span class="muted">({{.ConsecutiveFailures}}&times;)</span>{{end}}</td>
          <td class="num">{{if not .HasRun}}<span class="muted">&mdash;</span>{{else if .Overdue}}<span class="badge warn">overdue</span>{{else if le .NextRunInSec 0}}due{{else}}{{.NextRunIn}}{{end}}</td>
          <td class="num">{{if .HasRun}}{{.LastDurationMs}}ms{{else}}<span class="muted">&mdash;</span>{{end}}</td>
          <td>{{sparkline .DurationMsSeries}}{{outcomeStrip .OutcomeSeries}}</td>
          <td class="num">{{if .HasRun}}{{.Staleness}}{{else}}<span class="muted">&mdash;</span>{{end}}</td>
          <td class="mono">{{if .LastError}}{{.LastError}}{{else}}<span class="muted">&mdash;</span>{{end}}</td>
        </tr>
        {{else if .CoveredBy}}
        <tr>
          <td><code>{{.Name}}</code></td>
          <td><span class="badge info">covered</span></td>
          <td class="mono muted" colspan="9">collected via <code>{{.CoveredBy.Collector}}</code> ({{.CoveredBy.Transport}}) &middot; polled form off by design</td>
        </tr>
        {{else}}
        <tr class="skip">
          <td><code>{{.Name}}</code></td>
          <td><span class="badge {{skipBadgeClass .SkipCategory}}">{{if .SkipCategory}}{{.SkipCategory}}{{else}}skipped{{end}}</span></td>
          <td class="mono muted" colspan="9">skipped &mdash; {{.SkipReason}}</td>
        </tr>
        {{end}}
      {{else}}
        <tr><td colspan="11" class="muted">No collectors registered or skipped for this tenant.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>
  {{else}}
  <section><p class="muted">No tenants configured.</p></section>
  {{end}}
</main>
<footer>generated {{.GeneratedAt}} &middot; also at <code>/api/status.json</code></footer>
</body>
</html>
