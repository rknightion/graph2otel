    {
      "package": "internal/collectors/intune/hardwareinventory",
      "collectors": [
        "intune.hardware_inventory"
      ],
      "operations": [
        {
          "path": "/deviceManagement/managedDevices",
          "note": "the id-listing page walk only; hardwareInformation is a near-empty stub on this list form (live-measured 2026-07-21)"
        },
        {
          "path": "/deviceManagement/managedDevices/{id}",
          "note": "the single-entity GET is the only shape that populates hardwareInformation. It is delivered as a sub-request inside POST /$batch (20 per call); $batch itself is a transport envelope with no EDM binding, so the sub-request path is what the canary watches"
        }
      ]
    },
    {
      "package": "internal/collectors/intune/endpointanalytics",
      "collectors": [
        "intune.endpoint_analytics"
      ],
      "operations": [
        {
          "path": "/deviceManagement/userExperienceAnalyticsBaselines"
        },
        {
          "path": "/deviceManagement/userExperienceAnalyticsBatteryHealthDevicePerformance"
        },
        {
          "path": "/deviceManagement/userExperienceAnalyticsResourcePerformance"
        },
        {
          "path": "/deviceManagement/userExperienceAnalyticsAnomalySeverityOverview",
          "unmodeled": true,
          "type": "microsoft.graph.userExperienceAnalyticsAnomalySeverityOverview",
          "note": "live-measured: the endpoint returns 200 with this shape, but the beta EDM declares userExperienceAnalyticsAnomalySeverityOverview only as a ComplexType with no container or navigation binding, so there is nothing to walk. The type itself is still watched."
        },
        {
          "path": "/deviceManagement/userExperienceAnalyticsWorkFromAnywhereMetrics/allDevices/metricDevices",
          "resolve_as": "/deviceManagement/userExperienceAnalyticsWorkFromAnywhereMetrics/{id}/metricDevices",
          "note": "\"allDevices\" is a literal key, not a navigation segment \u2014 the only metric id this resource exposes"
        }
      ]
    },
    {
