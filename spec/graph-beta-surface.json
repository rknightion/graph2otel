{
  "metadata_url": "https://graph.microsoft.com/beta/$metadata",
  "note": "The Microsoft Graph BETA surface graph2otel consumes. Graph v1.0 is deliberately absent: it is a versioned, contractually stable surface, so drift value concentrates on beta. Paths are written without the /beta prefix, with {id} for key segments. Every package listed here builds a beta URL somewhere in its non-test Go source, and TestBetaSurfaceManifestCoversEveryBetaConsumer (internal/collectordoc) fails in both directions if that stops being true. See docs/api-drift.md.",
  "packages": [
    {
      "package": "internal/collectors/entra/agentriskdetections",
      "collectors": [
        "entra.agent_risk_detections"
      ],
      "operations": [
        {
          "path": "/identityProtection/agentRiskDetections"
        }
      ]
    },
    {
      "package": "internal/collectors/entra/recommendations",
      "collectors": [
        "entra.recommendations"
      ],
      "operations": [
        {
          "path": "/directory/recommendations"
        }
      ]
    },
    {
      "package": "internal/collectors/entra/riskyagents",
      "collectors": [
        "entra.risky_agents"
      ],
      "operations": [
        {
          "path": "/identityProtection/riskyAgents"
        }
      ]
    },
    {
      "package": "internal/collectors/entra/signinactivity",
      "collectors": [
        "entra.signin_activity"
      ],
      "operations": [
        {
          "path": "/reports/appCredentialSignInActivities"
        },
        {
          "path": "/reports/servicePrincipalSignInActivities"
        }
      ]
    },
    {
      "package": "internal/collectors/entra/signins",
      "collectors": [
        "entra.signins.non_interactive",
        "entra.signins.service_principal",
        "entra.signins.managed_identity"
      ],
      "operations": [
        {
          "path": "/auditLogs/signIns",
          "note": "the interactive stream polls the same path on v1.0; the other three are beta-only because the signInEventTypes filter is beta-only"
        }
      ]
    },
    {
      "package": "internal/collectors/intune/appletokens",
      "collectors": [
        "intune.apple_tokens"
      ],
      "operations": [
        {
          "path": "/deviceManagement/depOnboardingSettings"
