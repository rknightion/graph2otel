    {
      "package": "internal/collectors/intune/autopilot",
      "collectors": [
        "intune.autopilot"
      ],
      "operations": [
        {
          "path": "/deviceManagement/windowsAutopilotDeploymentProfiles"
        },
        {
          "path": "/deviceManagement/windowsAutopilotDeploymentProfiles/{id}/assignments"
        }
      ]
    },
    {
      "package": "internal/collectors/intune/autopilotevents",
      "collectors": [
        "intune.autopilot_events"
      ],
      "operations": [
