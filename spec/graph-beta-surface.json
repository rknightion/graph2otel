    {
      "package": "internal/collectors/intune/connectors",
      "collectors": [
        "intune.connectors"
      ],
      "operations": [
        {
          "path": "/deviceManagement/ndesConnectors",
          "note": "the exchange and mobile-threat-defense connectors on this collector are v1.0; only NDES is beta-only"
        }
